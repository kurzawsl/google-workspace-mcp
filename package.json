{
  "name": "google-workspace-mcp",
  "version": "1.0.0",
  "description": "MCP server exposing Gmail and Google Calendar to Claude via OAuth — read, send, and organize email; manage calendar events; extract attachment text",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsx src/index.ts",
    "auth": "tsx src/auth-setup.ts",
    "test": "npx tsx src/tests/attachment-path-validation.test.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "gmail",
    "google-calendar",
    "google-workspace"
  ],
  "author": "Lukasz Kurzawski (https://github.com/kurzawsl)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kurzawsl/google-workspace-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/kurzawsl/google-workspace-mcp/issues"
  },
  "homepage": "https://github.com/kurzawsl/google-workspace-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "google-auth-library": "^9.0.0",
    "googleapis": "^128.0.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  }
}
